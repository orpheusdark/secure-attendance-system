generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  student
  teacher
  admin
  super_admin
}

enum AttendanceStatus {
  present
  late
  suspicious
  rejected
  manual_review
}

enum VerificationMode {
  qr
  qr_plus_location
  qr_plus_face
  qr_plus_ble
  offline_signed
}

enum DeviceTrust {
  trusted
  new
  suspicious
  blocked
}

enum NotificationType {
  session_started
  attendance_reminder
  low_attendance_warning
  fraud_alert
  admin_announcement
  session_expiry
}

enum LogLevel {
  info
  warn
  error
  critical
}

enum SessionEventType {
  created
  opened
  qr_rotated
  scan_received
  validated
  locked
  expired
}

model Institution {
  id                   String               @id @default(cuid())
  name                 String
  code                 String               @unique
  timezone             String               @default("UTC")
  geofenceRadiusMeters Int                  @default(150)
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  departments          Department[]
  users                User[]
  classrooms           Classroom[]
  subjects             Subject[]
  attendanceSessions   AttendanceSession[]
}

model Department {
  id           String      @id @default(cuid())
  institutionId String
  name         String
  code         String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  institution  Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  users        User[]
  subjects     Subject[]

  @@unique([institutionId, code])
}

model User {
  id              String       @id @default(cuid())
  institutionId   String?
  departmentId    String?
  name            String
  email           String       @unique
  phone           String?      @unique
  passwordHash    String?
  role            UserRole
  deviceTrust     DeviceTrust  @default(new)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  institution     Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  department      Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  deviceRegistry  DeviceRegistry[]
  faceEmbeddings  FaceEmbedding[]
  attendance      AttendanceRecord[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  authSessions    AuthSession[]
  sessionsCreated AttendanceSession[] @relation("TeacherSessions")
}

model Subject {
  id            String      @id @default(cuid())
  institutionId String
  departmentId  String?
  name          String
  code          String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  sessions      AttendanceSession[]

  @@unique([institutionId, code])
}

model Classroom {
  id             String      @id @default(cuid())
  institutionId  String
  name           String
  building       String
  floor          String?
  latitude       Float
  longitude      Float
  accuracyMeters Int         @default(25)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  institution    Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  sessions       AttendanceSession[]
}

model AttendanceSession {
  id               String            @id @default(cuid())
  institutionId    String
  subjectId        String
  classroomId      String
  teacherId        String
  startsAt         DateTime
  endsAt           DateTime
  radiusMeters     Int
  verificationMode VerificationMode   @default(qr_plus_location)
  isLocked         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  institution      Institution       @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  subject          Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  classroom        Classroom         @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacher          User              @relation("TeacherSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  records          AttendanceRecord[]
  qrTokens         QrToken[]
  events           SessionEvent[]

  @@index([institutionId, startsAt])
}

model AttendanceRecord {
  id              String            @id @default(cuid())
  sessionId       String
  userId          String?
  status          AttendanceStatus  @default(manual_review)
  fraudScore      Int               @default(0)
  reasons         Json?
  distanceMeters  Float?
  deviceId        String?
  ipAddress       String?
  accuracyMeters  Float?
  selfieConfidence Float?
  motionScore     Float?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  session         AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId, status])
}

model QrToken {
  id         String            @id @default(cuid())
  sessionId   String
  tokenHash   String            @unique
  nonce       String
  issuedAt    DateTime          @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?
  revokedAt   DateTime?
  isOffline   Boolean           @default(false)
  session     AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, expiresAt])
}

model DeviceRegistry {
  id           String   @id @default(cuid())
  userId       String
  deviceId     String
  deviceName   String?
  platform     String?
  trustScore   Float    @default(0.5)
  lastIpAddress String?
  lastSeenAt   DateTime @default(now())
  isBlocked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
}

model FraudLog {
  id            String   @id @default(cuid())
  sessionId     String?
  userId        String?
  level         LogLevel @default(warn)
  category      String
  message       String
  metadata      Json?
  createdAt     DateTime @default(now())
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  type          NotificationType
  title         String
  message       String
  payload       Json?
  readAt        DateTime?
  createdAt     DateTime         @default(now())
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  institutionId String?
  action        String
  entity        String
  entityId      String?
  ipAddress     String?
  metadata      Json?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model FaceEmbedding {
  id            String   @id @default(cuid())
  userId        String
  provider      String   @default("local")
  embeddingHash String
  livenessScore Float    @default(0)
  confidence    Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsCache {
  id            String   @id @default(cuid())
  institutionId String
  key           String
  value         Json
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([institutionId, key])
}

model SessionEvent {
  id            String            @id @default(cuid())
  sessionId     String
  type          SessionEventType
  payload       Json?
  createdAt     DateTime          @default(now())
  session       AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, type])
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  deviceId         String
  accessTokenHash  String
  refreshTokenHash String   @unique
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deviceId])
  @@index([expiresAt])
}
